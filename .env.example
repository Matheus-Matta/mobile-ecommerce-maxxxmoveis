# App Expo - Maxxx Moveis
# Copie para .env e ajuste os valores.
# Nao coloque segredos em variaveis EXPO_PUBLIC_*.

# Ambiente do app: development | production
APP_ENV=development

# EAS / Expo Push
# Veja com: npx eas project:info
EAS_PROJECT_ID=e78b1455-d8d0-41a7-b9e3-16b6a67abff4
EXPO_PUBLIC_EAS_PROJECT_ID=e78b1455-d8d0-41a7-b9e3-16b6a67abff4

# WebView
EXPO_PUBLIC_SITE_URL=https://maxxxmoveis.com.br
EXPO_PUBLIC_ALLOWED_ORIGINS=https://maxxxmoveis.com.br,https://www.maxxxmoveis.com.br

# Backend Next.js de notificacoes.
# Use uma URL acessivel pelo celular. Nao use exp:// nem localhost no aparelho fisico.
# Exemplo local: http://192.168.100.12:3000
# Exemplo producao: https://api.maxxxmoveis.com.br
EXPO_PUBLIC_API_URL=

# Notificacoes no app
EXPO_PUBLIC_NOTIFICATION_CHANNEL_ID=maxxx-moveis-default
EXPO_PUBLIC_PUSH_TOKEN_STORAGE_KEY=expo_push_token

# Backend Next.js - somente para notifications-api/.env
# Estes valores estao aqui como referencia. Nao sao usados pelo app Expo.
DATABASE_URL=
NOTIFICATION_API_KEY=troque-esta-chave
