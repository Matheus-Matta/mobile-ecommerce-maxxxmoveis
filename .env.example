# Variáveis de Ambiente — Maxxx Móveis

# Shopify Storefront API
EXPO_PUBLIC_SHOPIFY_STORE_DOMAIN=sua-loja.myshopify.com
EXPO_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=seu-storefront-access-token
EXPO_PUBLIC_SHOPIFY_API_VERSION=2025-04

# ─── Menus e Metaobjects ──────────────────────────────────────────────────────
# Handle do menu de departamentos (DrawerMenu)
EXPO_PUBLIC_DEPARTMENTS_MENU_HANDLE=departments

# Handle do menu de categorias (CategoryStrip na home)
EXPO_PUBLIC_CATEGORIES_MENU_HANDLE=categories-strip

# Tipo do metaobject de banners (HeroBanner)
# Os metaobjects devem ter os campos: image (file_reference), link_url (url), alt_text (single_line_text_field), position (number_integer)
EXPO_PUBLIC_BANNER_METAOBJECT_TYPE=hero_banner
