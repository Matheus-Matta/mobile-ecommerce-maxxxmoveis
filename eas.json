{
  "cli": {
    "version": ">= 19.0.8"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "development"
      }
    },
    "production-apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://maxxxmoveis.com.br",
        "EXPO_PUBLIC_SITE_URL": "https://maxxxmoveis.com.br"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://maxxxmoveis.com.br",
        "EXPO_PUBLIC_SITE_URL": "https://maxxxmoveis.com.br"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
